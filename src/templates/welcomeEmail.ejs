<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Welcome to Easy Buy</title>

    <link
      href="https://fonts.googleapis.com/css?family=Lato:300,400,600,700"
      rel="stylesheet"
      type="text/css"
    />

    <style>
      body {
        margin: 0;
        padding: 0;
        -webkit-text-size-adjust: none;
        -ms-text-size-adjust: none;
        font-family: "Lato", Arial, sans-serif;
      }
      img {
        border: 0;
        display: block;
        line-height: 0;
      }
      a {
        text-decoration: none;
      }
    </style>
  </head>

  <body style="margin: 0; padding: 0; background: #ffffff">
    <center style="width: 100%; background: #ffffff">
      <!-- OUTER WRAPPER -->
      <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td align="center">
            <!-- MAIN CONTAINER -->
            <table
              width="720"
              cellpadding="0"
              cellspacing="0"
              border="0"
              style="
                max-width: 720px;
                background: #ffffff;
                border-radius: 16px;
                overflow: hidden;
              "
            >
              <!-- HEADER -->
              <tr>
                <td style="background: #000000; padding: 16px 24px">
                  <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                  >
                    <tr>
                      <td align="left" valign="middle">
                        <img src="/img/logo.png" height="34" alt="Easy Buy" />
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <!-- HERO -->
              <tr>
                <td align="center" valign="top">
                  <!--[if gte mso 9]>
                  <v:rect xmlns:v="urn:schemas-microsoft-com:vml" fill="true" stroke="false"
                    style="width:720px;height:300px;">
                    <v:fill type="frame" src="/img/welcome.jpg" />
                    <v:textbox inset="0,0,0,0">
                  <![endif]-->

                  <div
                    style="
                      background-image: linear-gradient(
                          rgba(0, 0, 0, 0.45),
                          rgba(0, 0, 0, 0.45)
                        ),
                        url('/img/welcome.jpg');
                      background-size: cover;
                      background-position: center;
                      height: 288px;
                      width: 781px;
                      text-align: center;
                      padding-top: 140px;
                      color: #ffffff;
                    "
                  >
                    <div style="font-size: 20px; line-height: 18px">
                      Welcome to
                    </div>

                    <div
                      style="
                        font-size: 34px;
                        font-weight: 700;
                        text-transform: uppercase;
                        letter-spacing: 0.12em;
                      "
                    >
                      EASY BUY
                    </div>

                    <a
                      href="<%= SHOP_URL %>"
                      style="
                        background: #ffffff;
                        color: #000000;
                        padding: 12px 28px;
                        border-radius: 50px;
                        display: inline-block;
                        margin-top: 12px;
                        font-size: 14px;
                        font-weight: 600;
                      "
                    >
                      Shop Now
                    </a>
                  </div>

                  <!--[if gte mso 9]>
                    </v:textbox>
                  </v:rect>
                  <![endif]-->
                </td>
              </tr>

              <!-- MAIN CONTENT -->
              <tr>
                <td style="padding: 36px 36px 10px; font-family: Lato, Arial">
                  <h2
                    style="
                      margin: 0;
                      font-size: 20px;
                      font-weight: 700;
                      color: #000;
                    "
                  >
                    Hi, <%= NAME %>
                  </h2>

                  <p style="font-size: 15px; color: #444; line-height: 1.6">
                    Your account is ready, and you can now explore uniforms made
                    to support your team's comfort, durability, and a
                    professional appearance—across different industries. Browse
                    at your own pace and place an order whenever it works for
                    you.
                  </p>

                  <p style="font-size: 15px; color: #444; line-height: 1.6">
                    For help or information, please visit our contact section.
                  </p>

                  <p
                    style="
                      font-size: 16px;
                      font-weight: 700;
                      color: #000000;
                      margin-bottom: 0;
                    "
                  >
                    Team Easy Buy,
                  </p>
                </td>
              </tr>

              <!-- Footer -->
              <tr>
                <td style="padding: 8px 32px 24px">
                  <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                  >
                    <tr>
                      <td width="40%" valign="middle">
                        <table cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td width="30%" valign="middle">
                              <img
                                src="/img/dark-logo.png"
                                style="height: 84px; display: block"
                              />
                            </td>
                            <td
                              style="
                                border-left: 2px solid #00000020;
                                padding-left: 20px;
                              "
                            >
                              <p
                                style="
                                  font-size: 12px;
                                  line-height: 1.7;
                                  margin: 0;
                                  color: #000000b2;
                                "
                              >
                                <b style="font-weight: 700; font-size: 16px"
                                  >Easy Buy Team</b
                                ><br />
                                RZ 448A, Street No 14B, Tughlakabad Extension,
                                New Delhi -110019<br />
                                7777901997<br />
                                onlinesupport@easybuy.com
                              </p>
                            </td>
                          </tr>
                        </table>
                      </td>
                      <td width="35%" align="right" valign="top">
                        <img src="/img/light-logo.png" style="display: block" />
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <tr>
                <td
                  style="
                    background: #f0f0f0;
                    margin-top: 20px;
                    padding: 20px 40px;
                    text-align: center;
                  "
                >
                  <table
                    width="100%"
                    cellpadding="0"
                    cellspacing="0"
                    border="0"
                  >
                    <tr>
                      <td
                        align="left"
                        valign="middle"
                        style="font-weight: 600; font-size: 13px"
                      >
                        <a
                          href="https://www.easybuy.com"
                          style="
                            color: black;
                            text-decoration: none;
                            display: inline-block;
                          "
                        >
                          www.easybuy.com
                        </a>
                      </td>
                      <td align="right" valign="middle">
                        <table cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td>
                              <a
                                href="https://www.instagram.com/easybuy_official/"
                                style="display: inline-block; margin: 0 16px"
                              >
                                <img
                                  src="/img/insta.png"
                                  alt="Instagram"
                                  style="display: block"
                                />
                              </a>
                            </td>
                            <td>
                              <a
                                href="https://www.facebook.com/ueasybuydesign/"
                                style="display: inline-block; margin: 0 16px"
                              >
                                <img
                                  src="/img/facebook.png"
                                  alt="Facebook"
                                  style="display: block"
                                />
                              </a>
                            </td>
                            <td>
                              <a
                                href="https://in.linkedin.com/company/easybuy"
                                style="display: inline-block; margin: 0 16px"
                              >
                                <img
                                  src="/img/linkedin.png"
                                  alt="LinkedIn"
                                  style="display: block"
                                />
                              </a>
                            </td>
                            <td>
                              <a
                                href="https://wa.me/7777901997"
                                style="display: inline-block; margin: 0 16px"
                              >
                                <img
                                  src="/img/whatsapp.png"
                                  alt="WhatsApp"
                                  width="22"
                                  height="22"
                                  style="display: block"
                                />
                              </a>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
            <!-- END MAIN CONTAINER -->
          </td>
        </tr>
      </table>
      <!-- END OUTER WRAPPER -->
    </center>
  </body>
</html>
