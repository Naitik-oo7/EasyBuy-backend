<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Proforma Invoice</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Lato", sans-serif;
        font-size: 11px; /* Reduced from 12px */
        color: #333;
        background: #f5f5f5;
        padding: 10px; /* Reduced from 20px */
        margin: 0;
      }

      .invoice-container {
        max-width: 800px;
        margin: 0 auto;
        background: #fff;
        box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
        padding: 10px; /* Reduced padding */
        border-radius: 16px;
        overflow: hidden;
      }

      .invoice-title {
        text-align: center;
        padding: 12px; /* Reduced from 16px */
        font-size: 18px; /* Reduced from 20px */
        font-weight: 700;
        border-bottom: 1px solid #ddd;
        margin-bottom: 10px; /* Added margin */
      }

      .header {
        background: #1a1a1a;
        color: #fff;
        display: flex;
        justify-content: space-between;
        padding: 12px 16px; /* Reduced padding */
        align-items: center;
      }

      .logo img {
        height: 40px; /* Fixed height */
      }

      .header-contact {
        font-size: 11px; /* Reduced from 12px */
        text-align: right;
        line-height: 1.4; /* Reduced from 1.5 */
      }

      .content {
        padding: 16px; /* Reduced from 24px */
      }

      .info-section {
        display: flex;
        justify-content: space-between;
        margin-bottom: 16px; /* Reduced from 24px */
        gap: 20px; /* Reduced from 40px */
      }

      .info-block {
        width: 50%;
      }

      .info-block h3 {
        font-size: 13px; /* Reduced from 15px */
        font-weight: 700;
        margin-bottom: 6px; /* Reduced from 8px */
        color: #000;
      }

      .info-block p {
        margin: 1px 0; /* Reduced from 2px */
        font-size: 11px; /* Reduced from 12px */
        line-height: 1.4; /* Reduced from 1.6 */
      }

      .company-name {
        font-weight: 700;
        font-size: 14px; /* Reduced from 16px */
        color: #000;
      }

      .info-section .info-block:first-child {
        border-right: 1px solid #ddd;
        padding-right: 15px; /* Reduced from 20px */
      }

      .info-section .info-block:last-child {
        padding-left: 15px; /* Reduced from 20px */
      }

      .invoice-ship-block {
        display: flex;
        justify-content: space-between;
        background: #f4f4f4;
        padding: 12px 20px; /* Reduced padding */
        margin-bottom: 16px; /* Reduced from 24px */
        gap: 20px; /* Reduced from 40px */
      }

      .invoice-details,
      .ship-to {
        width: 50%;
      }

      .invoice-details div {
        margin-bottom: 4px; /* Reduced from 6px */
        font-size: 11px; /* Reduced from 12px */
        line-height: 1.4; /* Reduced from 1.6 */
      }

      .invoice-details strong {
        font-weight: 700;
        font-size: 12px; /* Reduced from 13px */
        color: #000;
      }

      .ship-to h3 {
        font-size: 13px; /* Reduced from 15px */
        font-weight: 700;
        margin-bottom: 6px; /* Reduced from 8px */
        color: #000;
      }

      .ship-to p {
        margin: 1px 0; /* Reduced from 2px */
        font-size: 11px; /* Reduced from 12px */
        line-height: 1.4; /* Reduced from 1.6 */
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px; /* Reduced from 12px */
        border: 1px solid #ddd;
        border-radius: 4px; /* Reduced from 8px */
        margin-bottom: 16px; /* Added margin */
      }

      table thead th {
        background: #00000075;
        color: #ffffffb2;
        font-weight: 700;
        text-align: left;
        padding: 6px; /* Reduced from 8px */
        border: 1px solid #d0d0d0;
      }

      table tbody td {
        border-bottom: 1px solid #eee;
        padding: 6px; /* Reduced from 10px */
        vertical-align: top;
      }

      .item-description {
        font-weight: 700;
        color: #000;
        margin-bottom: 2px; /* Reduced from 4px */
      }

      .item-details {
        font-size: 10px; /* Reduced from 11px */
        color: #555;
        line-height: 1.3; /* Reduced from 1.5 */
      }

      .product-image {
        width: 60px;
        height: 80px;
        object-fit: cover;
        border-radius: 4px;
        margin-bottom: 8px;
      }

      /* Product image column width */
      .items-table th:nth-child(2),
      .items-table td:nth-child(2) {
        width: 80px;
        max-width: 80px;
      }

      .summary-section {
        border-top: none;
        margin-top: 0;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border: 1px solid #ddd;
        border-top: none;
        padding: 8px 6px 8px 8px; /* Reduced padding */
      }

      .order-summary {
        padding: 8px 12px; /* Reduced padding */
        font-weight: 700;
        font-size: 13px; /* Reduced from 14px */
      }

      .summary-table {
        width: 40%;
        padding: 8px 0 8px 12px; /* no right padding */
      }

      .summary-line {
        display: flex;
        justify-content: space-between;
        padding: 3px 0; /* Reduced from 5px */
        font-size: 11px; /* Reduced from 12px */
      }

      .summary-line.total {
        font-weight: 700;
        font-size: 12px; /* Reduced from 13px */
        border-top: 2px solid #333;
        margin-top: 6px; /* Reduced from 10px */
        padding-top: 4px; /* Reduced from 8px */
        padding-bottom: 4px; /* Reduced from 8px */
      }

      .tax-table-section h3 {
        font-size: 13px; /* Reduced from 14px */
        margin: 12px 0 8px; /* Reduced margins */
        font-weight: 700;
      }

      .tax-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px; /* Reduced from 10px */
        font-size: 11px; /* Reduced from 12px */
        border: 1px solid #d0d0d0;
      }

      .tax-table th {
        background: transparent;
        color: #666666;
        font-weight: 700;
        text-align: center;
        padding: 6px; /* Reduced from 8px */
        border: 1px solid #d0d0d0;
      }

      .tax-table td {
        text-align: right;
        padding: 6px; /* Reduced from 8px */
        border: 1px solid #d0d0d0;
        color: #333;
      }

      .tax-table .total-row td {
        font-weight: 700;
        font-size: 12px; /* Reduced from 14px */
        color: #000000;
        background: transparent;
      }

      .footer-note {
        text-align: center;
        font-size: 10px; /* Reduced from 11px */
        color: #666;
        padding: 12px; /* Reduced from 20px */
        border-top: 1px solid #ddd;
        margin-top: 15px; /* Reduced from 30px */
      }

      /* Right align price columns */
      .items-table td:nth-child(4),
      .items-table td:nth-child(5),
      .items-table td:nth-child(6),
      .items-table td:nth-child(7),
      .items-table td:nth-child(8) {
        text-align: right;
      }
      .items-table th:nth-child(4),
      .items-table th:nth-child(5),
      .items-table th:nth-child(6),
      .items-table th:nth-child(7),
      .items-table th:nth-child(8) {
        text-align: right;
      }

      /* Ensure content fits on one page */
      @page {
        size: A4;
        margin: 0.3cm; /* Reduced from 0.5cm */
      }
      table,
      tr,
      td,
      th {
        page-break-inside: auto !important;
      }

      .summary-section,
      .invoice-ship-block,
      .info-section {
        page-break-inside: avoid;
      }
    </style>
  </head>
  <body>
    <div class="invoice-container">
      <div class="invoice-title">Proforma Invoice</div>

      <div class="header">
        <div class="logo">
          <img src="/img/logo.png" alt="Easy Buy Logo" />
        </div>
        <div class="header-contact">
          <div>7777901997</div>
          <div>onlinesupport@easybuy.com</div>
        </div>
      </div>

      <div class="content">
        <div class="info-section">
          <div class="info-block">
            <h3>Billing address</h3>
            <p class="company-name"><%= billingName %></p>
            <p><%= billingAddress %></p>
            <p><%= billingPhone %></p>
            <p><%= billingEmail %></p>
          </div>
          <div class="info-block">
            <h3>Sold by :</h3>
            <p class="company-name">A Unit of NK Enterprises Pvt. Ltd</p>
            <p>
              RZ 448A, Street No 14B,<br />
              Tughlakabad Extension,<br />
              New Delhi - 110019
            </p>
            <p>GST No: 07AADCJ6419N1Z6</p>
            <p>UDYAM(MSME) No : UDYAM-DL-08-0018361</p>
          </div>
        </div>

        <div class="invoice-ship-block">
          <div class="invoice-details">
            <div><strong>PI :</strong> <%= invoiceNumber %></div>
            <div><strong>Date :</strong> <%= invoiceDate %></div>
            <div><strong>Order Number :</strong> <%= orderNumber %></div>
            <div><strong>Order Date :</strong> <%= orderDate %></div>
            <div><strong>Payment Method :</strong> <%= paymentMethod %></div>
          </div>
          <div class="ship-to">
            <h3>Ship to</h3>
            <p class="company-name"><%= shippingName %></p>
            <p><%= shippingAddress %></p>
            <p><%= shippingPhone %></p>
            <p><%= shippingEmail %></p>
          </div>
        </div>

        <table class="items-table">
          <thead>
            <tr>
              <th>S. No.</th>
              <th>Product</th>
              <th>Description</th>
              <th>Qty.</th>
              <th>Price</th>
              <th>Embroidery</th>
              <th>GST</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <%- itemsHtml %>
          </tbody>
        </table>

        <div class="summary-section">
          <div class="order-summary">Order Summary</div>
          <div class="summary-table">
            <div class="summary-line">
              <span>Product Sub Total</span>
              <span><%= productSubTotal %></span>
            </div>
            <% if (embroideryTotalRaw > 0) { %>
            <div class="summary-line">
              <span>Embroidery Charges</span>
              <span><%= embroideryDisplay %></span>
            </div>
            <% } %> <% if (couponDiscountRaw > 0) { %>
            <div class="summary-line">
              <span>Coupon Discount</span>
              <span>-<%= couponDiscountDisplay %></span>
            </div>
            <% } %>

            <div class="summary-line">
              <span><%= gstTypeLabel %></span>
              <span><%= productGstAmountDisplay %></span>
            </div>

            <div class="summary-line">
              <span>Shipping</span>
              <span><%= shippingBaseDisplay %></span>
            </div>

            <div class="summary-line">
              <span>18% GST (Shipping)</span>
              <span><%= shippingTaxDisplay %></span>
            </div>

            <!-- <div class="summary-line total">
              <span>Total GST</span>
              <span><%= totalGstDisplay %></span>
            </div> -->

            <div class="summary-line total" style="margin-top: 8px">
              <span>Payable Amount</span>
              <span><strong><%= payableDisplay %></strong></span>
            </div>
          </div>
        </div>

        <div class="tax-table-section">
          <h3>Tax Table</h3>
          <table class="tax-table">
            <thead class="tax-table-header">
              <% if (sameState) { %>
              <tr>
                <th rowspan="2">HSN/SAC</th>
                <th rowspan="2">Category</th>
                <th rowspan="2">Taxable Value</th>
                <th colspan="2">GST</th>
                <th rowspan="2">Total Amount<br />(With Tax)</th>
              </tr>
              <tr>
                <th>CGST</th>
                <th>SGST</th>
              </tr>
              <% } else { %>
              <tr>
                <th rowspan="2">HSN/SAC</th>
                <th rowspan="2">Category</th>
                <th rowspan="2">Taxable Value</th>
                <th colspan="2">IGST</th>
                <th rowspan="2">Total Amount<br />(With Tax)</th>
              </tr>
              <tr>
                <th>Rate</th>
                <th>Amount</th>
              </tr>
              <% } %>
            </thead>

            <tbody>
              <%- taxRowsHtml %> <% if (sameState) { %>
              <tr class="total-row">
                <td></td>
                <td><strong>Total</strong></td>
                <td><strong><%= taxableTotal %></strong></td>
                <td><strong>₹<%= cgstSum.toFixed(2) %></strong></td>
                <td><strong>₹<%= sgstSum.toFixed(2) %></strong></td>
                <td><strong><%= taxGrandTotal %></strong></td>
              </tr>
              <% } else { %>
              <tr class="total-row">
                <td></td>
                <td><strong>Total</strong></td>
                <td><strong><%= taxableTotal %></strong></td>
                <td><strong>-</strong></td>
                <td><strong>₹<%= igstSum.toFixed(2) %></strong></td>
                <td><strong><%= taxGrandTotal %></strong></td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="footer-note">This is a Computer Generated Invoice</div>
      </div>
    </div>
  </body>
</html>
