<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Order Status Update - <%= ORDER_NUMBER %></title>
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background: #f4f5f7;
      font-family: 'Lato', Arial, sans-serif;
      color: #333;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellpadding="0"
      cellspacing="0"
      border="0"
      style="background: #f4f5f7"
    >
      <tr>
        <td align="center" style="padding: 0;">
          <table
            role="presentation"
            width="100%"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="
              max-width: 700px;
              background: #ffffff;
              border-collapse: collapse;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            "
          >
            <tr>
              <td style="padding:0; background:#ffffff;">

                <table width="100%">
                 <tr>
                   <td style="padding: 0; background: #000000;">
                     <img
                       src="/img/email-bg-final.png"
                       alt="Easy Buy Order Update"
                     
                       style="
                         display: block;
                         width: 100%;
                         height: auto;
                         border: 0;
                       "
                     />
                   </td>
                </tr>
  
            <!-- Status Section -->
            <tr>
              <td style="padding:16px 32px 24px;">

                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td>
                      <h2
                        style="
                          text-align: center;
                          font-size: 20px;
                          font-weight: bolder;
                          "
                      >
                        Your uniform order is now <%= STATUS_MESSAGE %>
                      </h2>
                      <% if (TRACKING_URL && TRACKING_URL !== '#' && STATUS_MESSAGE.includes('shipped')) { %>
                     <p style="margin:0 0 8px;font-size:14px;">
                        Track your order :
                        <a href="<%= TRACKING_URL %>" style="color:#000;">
                          <%= TRACKING_URL %>
                        </a>
                      </p>
    
                      <p
                        style="
                          margin: 0 0 15px 0;
                          font-size: 14px;
                          color: #333;
                        "
                      >
                        Tracking ID: <strong><%= TRACKING_ID %></strong>
                      </p>
                      <% } %>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Shipping Info -->
            <tr>
              <td style="padding: 24px 32px">
                <table width="100%">
                  <tr>
                    <td
                      width="50%"
                      style="
                        padding-right: 20px;
                        border-right: 1px solid #e6e6e6;
                      "
                    >
                      <h3
                        style="
                          font-size: 15px;
                          font-weight: 800;
                          margin: 0 0 8px;
                        "
                      >
                        Shipped to
                      </h3>
                      <p
                        style="
                          font-weight: 700;
                          font-size: 14px;
                          margin: 0 0 6px;
                        "
                      >
                        <%= CUSTOMER_NAME %>
                      </p>
                      <p
                        style="
                          font-size: 13px;
                          line-height: 1.7;
                          color: #555;
                          margin: 0;
                        "
                      >
                        <%= ADDRESS_LINE_1 %><br />
                        <%= ADDRESS_LINE_2 %><br />
                        <%= ADDRESS_LINE_3 %><br />
                        <%= CUSTOMER_PHONE %><br />
                        <%= CUSTOMER_EMAIL %>
                      </p>
                    </td>
                    <td
                      width="50%"
                      style="padding-left: 20px; text-align: right"
                    >
                      <p><strong>PI:</strong> <%= ORDER_NUMBER %></p>
                      <p><strong>Date:</strong> <%= ORDER_DATE %></p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Package Details -->
            <tr>
              <td style="padding: 0 32px 24px">
                <h3
                  style="
                    font-size: 15px;
                    font-weight: 800;
                    color: #000;
                    margin: 0 0 10px 0;
                  "
                >
                  Package Details
                </h3>

                <table
                  width="100%"
                  style="border-collapse: collapse; font-size: 12px"
                >
                  <thead>
                    <tr style="background: #efefef; color: #333">
                      <th
                        align="left"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        S. No.
                      </th>
                      <th
                        align="left"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        Description
                      </th>
                      <th
                        align="center"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        Qty.
                      </th>
                      <th
                        align="right"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        Price
                      </th>
                      <th
                        align="right"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        Embroidery
                      </th>
                      <th
                        align="right"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        GST
                      </th>
                      <th
                        align="right"
                        style="padding: 10px; border: 1px solid #ddd"
                      >
                        Total
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    <% products.forEach((p, i) => { %>
                    <tr>
                      <td style="padding: 10px; border: 1px solid #eee">
                        <%= i + 1 %>
                      </td>
                      <td style="padding: 10px; border: 1px solid #eee">
                        <strong><%= p.PRODUCT_NAME %></strong><br />
                        <span style="font-size: 11px; color: #555">
                          Size: <%= p.SIZES %><br />
                          SKU: <%= p.SKU %><br />
                          HSN: <%= p.HSN %><br />
                          Embroidery: <%= p.EMBROIDERY_STATUS %>
                        </span>
                      </td>
                      <td
                        align="center"
                        style="padding: 10px; border: 1px solid #eee"
                      >
                        <%= p.QUANTITY %>
                      </td>
                      <td
                        align="right"
                        style="padding: 10px; border: 1px solid #eee"
                      >
                        <%= p.PRICE %>
                      </td>
                      <td
                        align="right"
                        style="padding: 10px; border: 1px solid #eee"
                      >
                        <%= p.EMBROIDERY_COST %>
                      </td>
                      <td
                        align="right"
                        style="padding: 10px; border: 1px solid #eee"
                      >
                        <%= p.GST_PERCENT %>
                      </td>
                      <td
                        align="right"
                        style="padding: 10px; border: 1px solid #eee"
                      >
                        <%= p.ITEM_TOTAL %>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>

                <table
                  width="100%"
                  style="
                    margin-top: 18px;
                    font-size: 13px;
                    border-collapse: collapse;
                  "
                >
                  <tr>
                    <td width="60%"></td>
                    <td width="40%">
                      <table width="100%">
                        <tr>
                          <td>Subtotal</td>
                          <td align="right"><%= SUBTOTAL %></td>
                        </tr>
                        <tr>
                          <td>Shipping</td>
                          <td align="right"><%= SHIPPING %></td>
                        </tr>
                        <tr>
                          <td>GST</td>
                          <td align="right"><%= GST_AMOUNT %></td>
                        </tr>
                        <tr>
                          <td
                            colspan="2"
                            style="border-top: 2px solid #333"
                          ></td>
                        </tr>
                        <tr>
                          <td style="font-weight: 800">Total</td>
                          <td align="right" style="font-weight: 800">
                            <%= TOTAL %>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            

            <!-- Footer -->
            <tr>
              <td style="border-top: 1px solid #e5e5e5; padding: 24px 32px">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td width="40%" valign="middle">
                      <table cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td width="30%" valign="middle">
                            <img
                              src="/img/dark-logo.png"
                              style="height: 84px; display: block"
                            />
                          </td>
                          <td
                            style="
                              border-left: 2px solid #00000020;
                              padding-left: 20px;
                            "
                          >
                            <p
                              style="
                                font-size: 12px;
                                line-height: 1.7;
                                margin: 0;
                                color: #000000b2;
                              "
                            >
                              <b style="font-weight: 700; font-size: 16px"
                                >Easy Buy Team</b
                              ><br />
                              RZ 448A, Street No 14B, Tughlakabad Extension, New
                              Delhi -110019<br />
                              7777901997<br />
                              onlinesupport@easybuy.com
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                    <td width="35%" align="right" valign="top">
                      <img
                        src="/img/light-logo.png"
                        style="display: block"
                      />
                    </td>
                  </tr>
                </table>
              </td>
            </tr>


            <!-- Automated Email Notice -->
            <tr>
              <td style="padding: 0px 30px 15px 30px; font-weight: bold; font-size: 12px; text-align: center;">
                Thank you for shopping with us! We appreciate your trust in Easy Buy.
              </td>
            </tr>
            <tr>
              <td
                style="
                  background: #f0f0f0;
                  margin-top: 20px;
                  padding: 20px 40px;
                  text-align: center;
                "
              >
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td
                      align="left"
                      valign="middle"
                      style="font-weight: 600; font-size: 13px"
                    >
                      <a
                        href="https://www.easybuy.com"
                        style="
                          color: black;
                          text-decoration: none;
                          display: inline-block;
                        "
                      >
                        www.easybuy.com
                      </a>
                    </td>
                    <td align="right" valign="middle">
                <table cellpadding="0" cellspacing="0" border="0">
                  <tr>
                   
                    <td>
                      <a
                        href="https://www.instagram.com/easybuy_official/"
                        style="display: inline-block; margin: 0 16px"
                      >
                        <img
                          src="/img/insta.png"
                          alt="Instagram"
                          style="display: block"
                        />
                      </a>
                    </td>
                    <td>
                      <a
                        href="https://www.facebook.com/ueasybuydesign/"
                        style="display: inline-block; margin: 0 16px"
                      >
                        <img
                          src="/img/facebook.png"
                          alt="Facebook"
                          style="display: block"
                        />
                      </a>
                    </td>
                    <td>
                      <a
                        href="https://in.linkedin.com/company/easybuy"
                        style="display: inline-block; margin: 0 16px"
                      >
                        <img
                          src="/img/linkedin.png"
                          alt="LinkedIn"
                          style="display: block"
                        />
                      </a>
                    </td>
                    <td>
                      <a
                        href="https://wa.me/7777901997"
                        style="display: inline-block; margin: 0 16px"
                      >
                        <img
                          src="/img/whatsapp.png"
                          alt="WhatsApp"
                          width="22"
                          height="22"
                          style="display: block"
                        />
                      </a>
                    </td>
                  </tr>
                </table>
              </td>   
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
