<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Corporate Account Approved - Uniform Bucket</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f5f5f5;
      font-family: 'Lato', Arial, sans-serif;
      color: #333;
    "
  >
    <table
      align="center"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="
        max-width: 800px;
        background: #ffffff;
        margin: 0 auto;
        border-collapse: collapse;
        border-radius: 16px;
        overflow: hidden;
      "
    >
      <!-- Header -->
      <tr>
        <td
          style="
            background-color: #000000;
            color: #ffffff;
            padding: 20px 30px;
            display: flex;
            align-items: center;
          "
        >
          <table width="100%" style="border-collapse: collapse">
            <tr>
              <td style="vertical-align: middle">
                <img
                  src="/img/logo.png"
                  alt="Uniform Bucket"
                  style="height: 40px; display: block"
                />
              </td>
              <td
                align="right"
                style="
                  text-align: right;
                  font-size: 12px;
                  color: #ffffff;
                  line-height: 1.6;
                "
              >
                <div>7777901997</div>
                <div>onlinesupport@easybuy.com</div>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Main Content -->
      <tr>
        <td style="padding: 30px; font-size: 15px; line-height: 1.6">
          <h2
            style="
              margin: 0 0 20px;
              font-size: 22px;
              font-weight: 700;
              color: #000;
            "
          >
            Corporate Account Approved
          </h2>

          <p>Dear <%= userName %>,</p>

          <p>
            We are pleased to inform you that your login request has been
            approved by the administrator.
          </p>

          <p>
            Your corporate account is now <strong>active</strong>, and you may
            log in using your registered credentials.
          </p>

          <p style="text-align: center; margin: 30px 0">
            <a
              href="<%= loginPortalUrl %>"
              style="
                background: #000000;
                color: #ffffff;
                padding: 12px 28px;
                border-radius: 50px;
                display: inline-block;
                font-size: 14px;
                font-weight: 600;
                text-decoration: none;
              "
            >
              Login Here
            </a>
          </p>

          <p style="margin-top: 30px">
            This is an automated message. Please do not reply to this email.
          </p>

          <p style="margin-top: 10px">
            Regards,<br />
            <strong>Easy Buy</strong>
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
